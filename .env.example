# Supabase PostgreSQL URI — from Supabase → Settings → Database → URI (psycopg2 format)
# e.g. postgresql://postgres:password@db.hatwuibhyddsulmfcnxz.supabase.co:5432/postgres
DATABASE_URL=

# Telegram — from BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Random secret string — used to verify Telegram webhook calls
TELEGRAM_WEBHOOK_SECRET=

# Your Render app URL (no trailing slash), e.g. https://my-app.onrender.com
WEBHOOK_BASE_URL=

# Anthropic API key for NLP parsing (optional — regex fallback used if not set)
ANTHROPIC_API_KEY=

# Weekly expense budget in your local currency
WEEKLY_BUDGET=150

# Set to true for local development (uses polling instead of webhook)
LOCAL_POLLING=false

# Dashboard login (leave DASHBOARD_PASSWORD blank to disable auth in local dev)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
